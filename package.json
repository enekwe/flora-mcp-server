{
  "name": "flora-mcp-server",
  "version": "1.0.0",
  "description": "Flora MCP Server microservice — IDE/CLI bridge connecting local agents to Flora Command Center's safety harness",
  "main": "src/index.js",
  "scripts": {
    "start": "node server.js",
    "start:sse": "MCP_TRANSPORT_MODE=sse node server.js",
    "dev": "nodemon server.js",
    "dev:sse": "MCP_TRANSPORT_MODE=sse nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js tools/**/*.js auth/**/*.js server.js",
    "lint:fix": "eslint src/**/*.js tools/**/*.js auth/**/*.js server.js --fix"
  },
  "keywords": [
    "mcp",
    "microservices",
    "ide-bridge",
    "command-center"
  ],
  "author": "Flora Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}

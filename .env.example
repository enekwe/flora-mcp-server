# Flora MCP Server Microservice — Environment Variables
# Per Flora Development Rules: use TCP proxy URLs on Railway, never *.railway.internal

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4005
SERVICE_NAME=flora-mcp-server

# ── Database (isolated MongoDB per microservice) ──────────────────────────────
# On Railway: use TCP proxy URL like mongodb://metro.proxy.rlwy.net:59998
# NEVER use mongodb.railway.internal
MONGODB_URI=mongodb://localhost:27017/flora_mcp_server

# ── Target Services (proxied by MCP server) ───────────────────────────────────
MONOLITH_API_URL=http://localhost:3001
COMMAND_CENTER_API_URL=http://localhost:4000

# ── Security ──────────────────────────────────────────────────────────────────
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-encryption-key-here
JWT_SECRET=your-jwt-secret-min-32-chars
INTERNAL_SERVICE_TOKEN=internal-service-token-for-cross-service-auth

# ── MCP Configuration ──────────────────────────────────────────────────────────
MCP_API_KEY_PREFIX=flora_mcp_
MCP_SESSION_TIMEOUT_MS=3600000
MCP_IDLE_TIMEOUT_MS=300000
MCP_MAX_CONNECTIONS_PER_USER=3
MCP_MAX_TOOL_CALLS_PER_MINUTE=60

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
